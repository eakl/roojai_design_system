# FVM Version Cache
.fvm/

# Local git worktrees (agent-created isolated workspaces)
.worktrees/

# This is a package (not an application); package lockfiles should not be
# committed. The example app's lockfile (example/pubspec.lock) is
# intentionally NOT covered by this rule and remains tracked.
/pubspec.lock
